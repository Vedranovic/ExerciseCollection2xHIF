<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="at.htlkaindorf.exa_502_numbersortingv2.controller.AppController">
   <children>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="20.0">
         <children>
            <Label text="Number of elements:" />
            <TextField fx:id="tfElements" prefHeight="31.0" prefWidth="198.0" />
            <Button fx:id="btGenerate" mnemonicParsing="false" text="Generate" />
         </children>
      </HBox>
      <HBox alignment="CENTER" prefHeight="76.0" prefWidth="500.0" spacing="50.0">
         <children>
            <RadioButton fx:id="rbSelectionSort" mnemonicParsing="false" text="Selection Sort">
               <toggleGroup>
                  <ToggleGroup fx:id="Sorting" />
               </toggleGroup></RadioButton>
            <RadioButton fx:id="rbBubbleSort" mnemonicParsing="false" text="Bubble Sort" toggleGroup="$Sorting" />
            <RadioButton fx:id="rbInsertionSort" mnemonicParsing="false" text="Insertion Sort" toggleGroup="$Sorting" />
         </children>
      </HBox>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="50.0">
         <children>
            <Button fx:id="btSort" mnemonicParsing="false" text="Sort" />
            <Label fx:id="lbMs" text="Not sorted yet!" />
         </children>
      </HBox>
      <TextArea fx:id="taOutput" prefHeight="200.0" prefWidth="200.0">
         <VBox.margin>
            <Insets bottom="10.0" left="10.0" right="10.0" />
         </VBox.margin>
      </TextArea>
   </children>
</VBox>
