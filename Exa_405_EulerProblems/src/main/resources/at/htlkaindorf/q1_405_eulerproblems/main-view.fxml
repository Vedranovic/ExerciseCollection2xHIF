                     <font>
                        <Font name="System Bold" size="23.0" />
                     </font>
                  </CheckBox>
               </children>
            </VBox>
         </content>
      </TitledPane>
      <Button mnemonicParsing="false" onAction="#onCalculate" prefHeight="31.0" prefWidth="416.0" text="Calculate">
         <VBox.margin>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </VBox.margin>
      </Button>
      <TitledPane text="Results">
         <content>
            <TextArea fx:id="taResults" editable="false" prefHeight="200.0" prefWidth="200.0" />
         </content>
      </TitledPane>
   </children>
</VBox>
