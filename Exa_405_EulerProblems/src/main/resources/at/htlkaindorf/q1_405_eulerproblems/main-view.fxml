                  <CheckBox fx:id="cbProblem1" mnemonicParsing="false" text="1 - Multiple of 3 and 5">
                     <VBox.margin>
                        <Insets bottom="3.0" />
                     </VBox.margin>
                     <font>
                        <Font name="System Bold" size="23.0" />
                     </font>
                  </CheckBox>
                  <CheckBox fx:id="cbProblem9" mnemonicParsing="false" text="9 - Special Pythagorean Triplet">
                     <VBox.margin>
                        <Insets bottom="3.0" />
                     </VBox.margin>
                     <font>
                        <Font name="System Bold" size="23.0" />
                     </font>
                  </CheckBox>
                  <CheckBox fx:id="cbProblem13" mnemonicParsing="false" text="13 - Large Sum">
                     <VBox.margin>
                        <Insets bottom="3.0" />
                     </VBox.margin>
                     <font>
                        <Font name="System Bold" size="23.0" />
                     </font>
                  </CheckBox>
                  <CheckBox fx:id="cbProblem20" mnemonicParsing="false" text="20 - Factorial Digit">
                     <VBox.margin>
                        <Insets bottom="3.0" />
                     </VBox.margin>
                     <font>
                        <Font name="System Bold" size="23.0" />
                     </font>
                  </CheckBox>
                  <CheckBox fx:id="cbProblem48" mnemonicParsing="false" text="48 - Self Powers">
                     <VBox.margin>
                        <Insets bottom="3.0" />
