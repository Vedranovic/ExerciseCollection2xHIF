<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="450.0" prefWidth="500.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="at.htlkaindorf.exa_501_carfactoryv2.controller.AppController">
   <children>
      <GridPane prefHeight="178.0" prefWidth="580.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="200.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="Brand" />
            <Label text="Model" GridPane.rowIndex="1" />
            <Label text="Price" GridPane.rowIndex="2" />
            <Label text="Release Date" GridPane.rowIndex="3" />
            <TextField fx:id="tfBrand" GridPane.columnIndex="1" />
            <TextField fx:id="tfModel" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <TextField fx:id="tfPrice" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <TextField fx:id="tfReleaseDate" promptText="dd.MM.yyyy" GridPane.columnIndex="1" GridPane.rowIndex="3" />
         </children>
         <VBox.margin>
            <Insets left="10.0" right="10.0" top="10.0" />
         </VBox.margin>
      </GridPane>
      <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0" spacing="30.0">
         <children>
            <Button fx:id="btAdd" mnemonicParsing="false" text="ADD" />
            <Button mnemonicParsing="false" onAction="#onDelete" text="DELETE" />
            <Button fx:id="btChange" mnemonicParsing="false" text="CHANGE" />
            <Button fx:id="btClear" mnemonicParsing="false" text="CLEAR" />
            <Button mnemonicParsing="false" onAction="#onLoad" text="LOAD" />
         </children>
      </HBox>
      <ListView fx:id="lvOutput" prefHeight="200.0" prefWidth="200.0">
         <VBox.margin>
            <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
         </VBox.margin>
      </ListView>
   </children>
</VBox>
