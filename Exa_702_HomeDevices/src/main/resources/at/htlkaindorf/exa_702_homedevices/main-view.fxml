<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.shape.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import java.lang.*?>
<?import javafx.scene.layout.*?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="at.htlkaindorf.exa_702_homedevices.controller.AppController">
   <children>
      <ListView fx:id="lvData" onMouseClicked="#onDeviceSelected" prefHeight="400.0" prefWidth="600.0">
         <VBox.margin>
            <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
         </VBox.margin>
      </ListView>
      <HBox alignment="CENTER" spacing="40.0">
         <children>
            <Button fx:id="btLoadFile" mnemonicParsing="false" text="Load File" />
            <Button fx:id="btOnOff" mnemonicParsing="false" text="ON / OFF" />
            <Button fx:id="btConnectDisconnect" mnemonicParsing="false" text="Connect / Disconnect" />
            <Button fx:id="btSetBrightness" mnemonicParsing="false" text="Set Brightness" />
         </children>
         <padding>
            <Insets bottom="10.0" />
         </padding>
      </HBox>
      <GridPane vgap="5.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
            <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <VBox.margin>
            <Insets bottom="50.0" left="10.0" right="10.0" top="10.0" />
         </VBox.margin>
         <children>
            <TextField fx:id="tfName" editable="false" GridPane.columnIndex="1" />
            <TextField fx:id="tfEnergy" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Label text="Name:" />
            <Label text="State:" GridPane.rowIndex="1" />
            <Label text="Energy:" GridPane.rowIndex="2" />
            <HBox alignment="CENTER_LEFT" prefHeight="100.0" prefWidth="200.0" spacing="20.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
               <children>
                  <Circle fx:id="clActivated" fill="RED" radius="13.0" stroke="BLACK" strokeType="INSIDE" />
                  <Circle fx:id="clConnection" fill="#800202" radius="13.0" stroke="BLACK" strokeType="INSIDE" />
                  <Circle fx:id="clBrightness" fill="#a6a7a8" radius="13.0" stroke="BLACK" strokeType="INSIDE" />
               </children>
            </HBox>
            <Label fx:id="lbDrumSize" text="Drum Size:" GridPane.rowIndex="3" />
            <TextField fx:id="tfDrumSize" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="3" />
         </children>
      </GridPane>
   </children>
</VBox>
